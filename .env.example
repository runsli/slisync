# Slisync — docs: docs/en/ (default), docs/zh/, packages/README.md
#
# HTTP bind address (default 0.0.0.0 in dev)
# HOST=0.0.0.0

# Next.js dev allowlist host — your Mac LAN IP, e.g. 192.168.1.23
# NEXT_DEV_HOST=192.168.1.23

# Optional: force Socket.IO URL if page origin differs
# NEXT_PUBLIC_SYNC_URL=http://192.168.1.23:3000

# Phase 5: standalone sync server (npm run sync:server)
# SYNC_PORT=3001
# SYNC_HOST=0.0.0.0
# NEXT_PUBLIC_SYNC_URL=http://192.168.1.23:3001

# --- P0: Redis + protocol ---
# Optional: Redis persistence (production)
# REDIS_URL=redis://localhost:6379

# Socket.IO cross-process broadcast (default on when REDIS_URL is set)
# SYNC_SOCKET_ADAPTER=0

# Wire protocol v1 (schema constant; clients send X-Sync-Protocol-Version)
# GET /v1/sync/capabilities — server features + agent policy snapshot

# --- P0/P1: Persistence ---
# Optional: local JSON file when REDIS_URL is unset (default: .sync-data/rooms.json)
# SYNC_DATA_PATH=./.sync-data/rooms.json

# Optional: CRDT (Yjs) snapshot storage (default: .sync-data/crdt-rooms.json)
# SYNC_CRDT_DATA_PATH=./.sync-data/crdt-rooms.json
# Optional: PostgreSQL CRDT store (overrides file when set; ignored if REDIS_URL is set)
# npm run postgres:up && npm run dev:postgres
# SYNC_CRDT_POSTGRES_URL=postgres://slisync:slisync@localhost:5432/slisync
# Export memory_chunk → Markdown (see docs/zh/export.md)
# Local after seed: npm run export:chunks
# CI / no dev: npm run export:chunks:ci  → fixtures/crdt-rooms.example.json
# SYNC_CRDT_DATA_PATH=./fixtures/crdt-rooms.example.json

# P1-6: Audit trail append-only JSONL
# SYNC_AUDIT_PATH=./.sync-data/audit.jsonl
# SYNC_AUDIT_MEMORY=1

# --- Phase 8: Auth ---
# SYNC_AUTH_REQUIRED=1
# SYNC_API_KEY=<your-room-api-key>
# SYNC_AGENT_API_KEY=<your-agent-api-key>
# SYNC_ROOM_KEYS={"example-room":"<your-room-api-key>"}

# Browser demo (only when auth enabled; keys are visible in the client bundle)
# NEXT_PUBLIC_SYNC_API_KEY=<your-room-api-key>
# NEXT_PUBLIC_SYNC_AGENT_API_KEY=<your-agent-api-key>

# --- Phase 8 / P3: Agent graph policy (see GET /v1/sync/capabilities) ---
# SYNC_AGENT_GRAPH_RELATIONS=related_to,derived_from,references,contains,depends_on,assigned_to
# SYNC_AGENT_GRAPH_KINDS=workspace,session,memory_chunk,project,memory,task,file,custom,agent_run
# SYNC_AGENT_GRAPH_OPS=upsertNode,upsertEdge,addTag,addRef
# SYNC_AGENT_MAX_GRAPH_OPS=50
# SYNC_AGENT_DENY_MEMORY=1

# --- Phase 10: Graph HTTP ---
# SYNC_HTTP_URL=http://localhost:3001

# --- P2: Graph seed (scoped workspace/session/chunk by default) ---
# SYNC_GRAPH_SCOPED=0   # set to 0 for legacy project/task/file demo graph
