# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
packages/*/dist/

# misc
.DS_Store
*.pem

# IDE / agent rules (not part of the product)
AGENTS.md
CLAUDE.md
.cursor/

# Maintainer-only (npm release notes — not for public repo)
PUBLISH.md
PUBLISH.example.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Phase 3/CRDT local sync persistence + audit trail
.sync-data/

# M2: generated chunk export (npm run export:chunks)
/markdown/chunks/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
