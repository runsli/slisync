{
  "name": "slisync",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "predev": "node scripts/check-node.mjs",
    "dev:stop": "node scripts/stop-dev.mjs",
    "sync:reset": "node scripts/reset-sync-data.mjs",
    "sync:server": "npm run start -w @slisync/sync-server",
    "sync:server:dev": "npm run dev -w @slisync/sync-server",
    "agent:push": "tsx scripts/agent-push.ts",
    "graph:smoke": "tsx scripts/graph-smoke.ts",
    "graph:seed": "tsx scripts/graph-seed.ts",
    "task:seed": "tsx scripts/task-seed.ts",
    "export:chunks": "tsx scripts/export-chunks.ts",
    "export:chunks:ci": "CI=1 tsx scripts/export-chunks.ts",
    "export:chunks:http": "tsx scripts/export-chunks-http.ts",
    "fixtures:refresh": "node --import tsx scripts/refresh-crdt-fixture.mjs",
    "graph:push:http": "tsx scripts/graph-push-http.ts",
    "graph:traverse:http": "tsx scripts/graph-traverse-http.ts",
    "graph:policy": "tsx scripts/validate-graph-policy.ts",
    "dev": "tsx watch server.ts",
    "build": "next build",
    "prestart": "node scripts/check-node.mjs",
    "start": "NODE_ENV=production tsx server.ts",
    "build:packages": "npm run build -w @slisync/sync-schema && npm run build -w @slisync/sync-sdk && npm run build -w @slisync/sync-server",
    "test": "node --import tsx --test --test-concurrency=1 tests/unit/export-chunks.test.ts tests/unit/export-http-query.test.ts tests/unit/export-http-accept.test.ts tests/unit/fetch-export-chunks-http.test.ts tests/unit/indexeddb-room-store.test.ts tests/unit/merge-local-remote.test.ts tests/unit/persistent-crdt-outbox.test.ts tests/unit/task-model.test.ts tests/unit/task-bus.test.ts tests/unit/agent-graph-policy-server.test.ts tests/integration/crdt-indexeddb-persistence.test.ts tests/integration/crdt-local-persistence.test.ts tests/integration/sync-graph.test.ts tests/integration/task-bus-sync.test.ts tests/integration/protocol-version.test.ts tests/integration/audit-crdt-authority.test.ts tests/integration/scoped-memory-presence.test.ts tests/integration/crdt-offline-outbox.test.ts tests/integration/sync-capabilities.test.ts tests/integration/export-http.test.ts",
    "test:integration": "npm run test",
    "test:cluster": "node --import tsx --test tests/integration/redis-cluster.test.ts",
    "lint": "eslint",
    "redis:up": "docker compose up -d redis",
    "dev:redis": "REDIS_URL=redis://localhost:6379 npm run dev",
    "postgres:up": "docker compose up -d postgres",
    "dev:postgres": "SYNC_CRDT_POSTGRES_URL=postgres://slisync:slisync@localhost:5432/slisync npm run dev",
    "test:postgres": "node --import tsx --test tests/integration/crdt-postgres-persistence.test.ts"
  },
  "dependencies": {
    "@slisync/sync-sdk": "*",
    "@slisync/sync-server": "*",
    "fast-json-patch": "^3.1.1",
    "ioredis": "^5.10.1",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "undici": "^7.25.0",
    "yjs": "^13.6.30",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.41",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "fflate": "^0.8.2",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
