{
  "name": "@slisync/sync-server",
  "version": "0.1.0",
  "description": "Slisync Socket.IO server (LWW + CRDT + Graph HTTP)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["dist", "src", "README.md"],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
      "slisync-server": "./dist/standalone.js"
    }
  },
  "license": "MIT",
  "bin": {
    "slisync-server": "./src/standalone.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "start": "tsx src/standalone.ts",
    "dev": "tsx watch src/standalone.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@slisync/sync-schema": "^0.1.0",
    "@slisync/sync-sdk": "^0.1.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "fast-json-patch": "^3.1.1",
    "ioredis": "^5.10.1",
    "pg": "^8.16.0",
    "socket.io": "^4.8.3",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "tsx": "^4.22.3"
  }
}
